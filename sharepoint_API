import logging
import os
import traceback
from office365.runtime.auth.user_credential import UserCredential
from office365.sharepoint.client_context import ClientContext

class SharePointAPI:
    def __init__(self, username, password, sharepoint_url, sharepoint_site):
        self.username = username
        self.password = password
        self.sharepoint_url = sharepoint_url
        self.sharepoint_site = sharepoint_site
        self.ctx = ClientContext(self.sharepoint_url + self.sharepoint_site).with_credentials(
            UserCredential(self.username, self.password))
        logging.info(f"Initialized SharePoint context for {self.sharepoint_url + self.sharepoint_site}.")

    def upload_file(self, file_path, folder_path):
        file_name = os.path.basename(file_path)
        target_folder = self.ctx.web.get_folder_by_server_relative_url(folder_path)
        with open(file_path, 'rb') as file_content:
            try:
                target_file = target_folder.upload_file(file_name, file_content).execute_query()
                logging.info(f"File {file_name} uploaded successfully to {folder_path}.")
            except Exception as e:
                logging.error(f"Failed to upload {file_name} to {folder_path}: {e}")
                logging.error(traceback.format_exc())

    def create_folder(self, folder_path):
        folder_name = os.path.basename(folder_path)
        try:
            self.ctx.web.folders.add(folder_path).execute_query()
            logging.info(f"Folder {folder_name} created successfully in SharePoint.")
        except Exception as e:
            logging.error(f"Failed to create folder {folder_name} in SharePoint: {e}")
            logging.error(traceback.format_exc())

    def ensure_folder_structure(self, folder_path):
        logging.info(f"Ensuring folder structure for path {folder_path}")
        folders = folder_path.split('/')
        current_path = ''

        for folder in folders:
            if current_path:
                current_path = f"{current_path}/{folder}"
            else:
                current_path = folder

            try:
                self.ctx.web.folders.add(current_path).execute_query()
                logging.info(f"Ensured folder {current_path} exists.")
            except Exception as e:
                if "A folder with the name already exists" in str(e):
                    logging.debug(f"Folder {current_path} already exists.")
                else:
                    logging.error(f"Failed to ensure folder {current_path}: {e}")
                    logging.error(traceback.format_exc())



