import logging
import os
import traceback
import requests


class SharePointAPI:
    def __init__(self, config, vault_secrets, webapps_info):
        self.base_url = config["sharepoint_url"]
        self.site_path = config["sharepoint_site"]
        self.webapps_info = webapps_info

        # SPN credentials from vault
        self.client_id = vault_secrets['sp_client_id']
        self.client_secret = vault_secrets['sp_client_secret']
        self.tenant_id = vault_secrets['sp_tenant_id']

        self.token = self.authenticate()

        logging.info("✅ SharePoint API initialized (SPN)")

    # -------------------------
    # AUTH
    # -------------------------
    def authenticate(self):
        url = f"https://login.microsoftonline.com/{self.tenant_id}/oauth2/v2.0/token"

        data = {
            'grant_type': 'client_credentials',
            'client_id': self.client_id,
            'client_secret': self.client_secret,
            'scope': 'https://graph.microsoft.com/.default'
        }

        response = requests.post(url, data=data)

        if response.status_code == 200:
            logging.info("✅ SPN authentication successful")
            return response.json()['access_token']
        else:
            logging.error(f"❌ Auth failed: {response.text}")
            raise Exception("Authentication failed")

    def get_headers(self):
        return {
            "Authorization": f"Bearer {self.token}",
            "Content-Type": "application/octet-stream"
        }

    # -------------------------
    # UPLOAD (ONLY WHAT YOU NEED)
    # -------------------------
    def upload_file(self, file_path, appID):
        try:
            file_name = os.path.basename(file_path)

            webapp_info = self.webapps_info[appID]
            folder_path = webapp_info["paths_path"]

            # Full SharePoint relative path
            full_path = f"{self.site_path}/{folder_path}/{file_name}"

            url = f"https://graph.microsoft.com/v1.0/me/drive/root:/{full_path}:/content"

            with open(file_path, "rb") as f:
                response = requests.put(url, headers=self.get_headers(), data=f)

            if response.status_code in [200, 201]:
                logging.info(f"✅ Uploaded {file_name} to {full_path}")
            else:
                logging.error(f"❌ Upload failed: {response.text}")

        except Exception as e:
            logging.error(f"Upload error: {e}")
            logging.error(traceback.format_exc())
