import requests
import logging
import os
import traceback


class SharePointAPI:

    def __init__(self, tenant_id, client_id, client_secret, site_url):
        self.tenant_id = tenant_id
        self.client_id = client_id
        self.client_secret = client_secret
        self.site_url = site_url.rstrip("/")

        self.access_token = None
        self.headers = None

        logging.info("Initializing SharePoint API...")
        self.authenticate()
        self.site_id = self.get_site_id()
        logging.info(f"Connected to SharePoint site_id={self.site_id}")

    # 🔐 AUTHENTICATION
    def authenticate(self):
        try:
            logging.info("Requesting SharePoint access token...")

            url = f"https://login.microsoftonline.com/{self.tenant_id}/oauth2/v2.0/token"

            payload = {
                "client_id": self.client_id,
                "client_secret": self.client_secret,
                "scope": "https://graph.microsoft.com/.default",
                "grant_type": "client_credentials"
            }

            response = requests.post(url, data=payload)
            response.raise_for_status()

            token_data = response.json()
            self.access_token = token_data["access_token"]

            self.headers = {
                "Authorization": f"Bearer {self.access_token}",
                "Content-Type": "application/json"
            }

            logging.info("SharePoint authentication successful")

        except Exception as e:
            logging.error("Authentication failed")
            logging.error(traceback.format_exc())
            raise

    # 🔎 GET SITE ID
    def get_site_id(self):
        try:
            logging.info("Resolving SharePoint site ID...")

            # Example: https://company.sharepoint.com/sites/MySite
            domain = self.site_url.split("/")[2]
            site_path = "/".join(self.site_url.split("/")[3:])

            url = f"https://graph.microsoft.com/v1.0/sites/{domain}:/sites/{site_path}"

            response = requests.get(url, headers=self.headers)
            response.raise_for_status()

            site_id = response.json()["id"]

            logging.info(f"Resolved site_id={site_id}")
            return site_id

        except Exception as e:
            logging.error("Failed to get site ID")
            logging.error(traceback.format_exc())
            raise

    # 📂 GET DEFAULT DRIVE ID
    def get_drive_id(self):
        try:
            logging.info("Getting SharePoint drive ID...")

            url = f"https://graph.microsoft.com/v1.0/sites/{self.site_id}/drive"

            response = requests.get(url, headers=self.headers)
            response.raise_for_status()

            drive_id = response.json()["id"]

            logging.info(f"Drive ID={drive_id}")
            return drive_id

        except Exception as e:
            logging.error("Failed to get drive ID")
            logging.error(traceback.format_exc())
            raise

    # 📁 ENSURE FOLDER EXISTS
    def ensure_folder(self, drive_id, folder_path):
        try:
            logging.info(f"Ensuring folder path exists: {folder_path}")

            parts = folder_path.strip("/").split("/")
            current_path = ""

            for part in parts:
                current_path = f"{current_path}/{part}" if current_path else part

                url = f"https://graph.microsoft.com/v1.0/drives/{drive_id}/root:/{current_path}"

                response = requests.get(url, headers=self.headers)

                if response.status_code == 404:
                    logging.debug(f"Creating folder: {current_path}")

                    parent = "/".join(current_path.split("/")[:-1])
                    parent_url = f"https://graph.microsoft.com/v1.0/drives/{drive_id}/root:/{parent}:/children" if parent else f"https://graph.microsoft.com/v1.0/drives/{drive_id}/root/children"

                    data = {
                        "name": part,
                        "folder": {},
                        "@microsoft.graph.conflictBehavior": "replace"
                    }

                    create = requests.post(parent_url, headers=self.headers, json=data)
                    create.raise_for_status()

                else:
                    logging.debug(f"Folder exists: {current_path}")

        except Exception as e:
            logging.error(f"Failed ensuring folder {folder_path}")
            logging.error(traceback.format_exc())
            raise

    # 📤 UPLOAD FILE
    def upload_file(self, file_path, folder_path):
        try:
            logging.info("----- SHAREPOINT UPLOAD START -----")

            if not os.path.exists(file_path):
                raise Exception(f"File not found: {file_path}")

            file_name = os.path.basename(file_path)
            logging.info(f"Uploading file: {file_name}")

            drive_id = self.get_drive_id()

            # Ensure folder exists
            self.ensure_folder(drive_id, folder_path)

            upload_url = f"https://graph.microsoft.com/v1.0/drives/{drive_id}/root:/{folder_path}/{file_name}:/content"

            logging.debug(f"Upload URL: {upload_url}")

            with open(file_path, "rb") as f:
                response = requests.put(upload_url, headers={
                    "Authorization": f"Bearer {self.access_token}",
                    "Content-Type": "application/octet-stream"
                }, data=f)

            response.raise_for_status()

            logging.info(f"File uploaded successfully → {folder_path}/{file_name}")
            logging.info("----- SHAREPOINT UPLOAD END -----")

        except Exception as e:
            logging.error("Upload failed")
            logging.error(traceback.format_exc())
            raise
