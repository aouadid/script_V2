    update_webapps_info(webapp_id, webapp_name, webapp_title, scope, webapp_url, webapp_int, webapp_env, kdbx_path, paths_path)
    directory_path = os.path.join(WAS_REPORTS_PATH, scope, webapp_title, current_year, webapp_env)
    if not os.path.exists(directory_path):
        os.makedirs(directory_path)
        logging.info(f"Created directory structure at {directory_path}")

    password = generate_password()
    if not os.path.exists(os.path.join(WAS_REPORTS_PATH, kdbx_path)):
        keepass_manager.create_keepass_db(os.path.join(WAS_REPORTS_PATH, kdbx_path), password)
        logging.info(f"Created KeePass database for {webapp_title}")

        keepass_manager.handle_master_kdbx(webapp_id, password, vault_secrets['master_password'])
        keepass_manager.handle_root_kdbx(kdbx_path, password, os.path.join(WAS_REPORTS_PATH, scope),
                                         vault_secrets['root_password'])
        logging.info(f"Stored credentials in KeePass for {webapp_title}")

    # qualys_onboard = str(input("Do you want to onboard application on Qualys as well? yes/no"))
    # if qualys_onboard.lower() == "yes":
    #     if qualys_api.check_health():
    #         webapp_profile = qualys_api.webapp_create(webapp_title, webapp_url, scope, ["154370904", "105772133"],
    #                                                   webapp_int)
