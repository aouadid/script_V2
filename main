# Setup logging
logging.basicConfig(filename='script.log', level=logging.DEBUG, format='%(asctime)s [%(levelname)s] %(message)s')

try:
    VAULT_KDBX = 'config/vault.kdbx'
    CONFIG_YML = 'config/config.yml'
    config = load_config(CONFIG_YML)
    CONFIG_PATH = os.path.join(Path.home(), config["remote_config"]).replace("_", "\u2013")
    WEBAPPS_INFO = os.path.join(CONFIG_PATH, 'webapps_info.json')
    MASTER_KDBX = os.path.join(CONFIG_PATH, 'Apps.kdbx')
    ROOT_KDBX = os.path.join(CONFIG_PATH, 'Scopes.kdbx')
    BACKUP_PATH = os.path.join(CONFIG_PATH, 'Backup.kdbx')
    VAULT_SECRETS = ['qualys_user', 'qualys_pwd', 'proxy_user', 'proxy_password', 'master_password',
                     'root_password', 'backup_password', 'sharepoint_user', 'sharepoint_password']
    WAS_REPORTS_PATH = os.path.join(Path.home(), config["sharepoint_site"]).replace("_", "\u2013")
except Exception as e:
    logging.error(f"Error initializing: {e}")


def initialize_vault(keepass_manager):
    logging.info("Initializing vault...")
    if not os.path.exists(VAULT_KDBX):
        vault_password = generate_password()
        keepass_manager.create_keepass_db(kdbx_path=VAULT_KDBX, password=vault_password)
        logging.info(f"Vault created at {VAULT_KDBX}.")
        print(f"Vault password: {vault_password}")
        input("Please save this password securely and press any key to continue...")
    logging.info("Vault exists, proceeding with loading...")

    try:
        logging.info("Prompting for vault password...")
        #vault_password = getpass("Enter vault.kdbx password: ")
        vault_password = "e2fr1Ey!TWb9LPOFwC#e$Hx4"
        logging.info("Vault password entered.")

        kp = pykeepass.PyKeePass(VAULT_KDBX, password=vault_password)
        logging.info("Vault opened.")

        for secret in VAULT_SECRETS:
            logging.info(f"Checking secret: {secret}")
            entry = kp.find_entries(title=secret, first=True)
            if not entry or not entry.password:
                secret_value = getpass(f"Enter value for {secret}: ")
                if entry:
                    entry.password = secret_value
                else:
                    kp.add_entry(kp.root_group, title=secret, username="user", password=secret_value)
                kp.save()
                logging.info(f"Stored {secret} in vault.")

        secrets = {secret: kp.find_entries(title=secret, first=True).password for secret in VAULT_SECRETS}
        logging.info("All secrets loaded from vault.")
        return secrets
    except Exception as e:
        logging.error(f"Failed to load vault: {e}")
        logging.error(traceback.format_exc())
        raise


def generate_password():
    pwo = PasswordGenerator()
    pwo.minlen = 20
    pwo.maxlen = 25
    pwo.excludeschars = "^.*`'~,&"
    return pwo.generate()


def load_webapps_info():
    try:
        with open(WEBAPPS_INFO, 'r') as jsonfile:
            logging.info("Loaded webapps info successfully.")
            return json.load(jsonfile)
    except Exception as e:
        logging.error(f"Failed to load webapps info: {e}")
        return {}


def update_webapps_info(webapp_id, webapp_name, webapp_title, scope, webapp_url, webapp_int,webapp_env, kdbx_path, paths_path):
    try:
        data = load_webapps_info()
        data[webapp_id] = {
            "webapp_name": webapp_name,
            "webapp_title": webapp_title,
            "scope": scope,
            "webapp_url": webapp_url,
            "webapp_int": webapp_int,
            "webapp_env": webapp_env,
            "kdbx_path": kdbx_path,
            "paths_path": paths_path
        }
        with open(WEBAPPS_INFO, 'w') as jsonfile:
            json.dump(data, jsonfile, indent=4)
        logging.info(f"Webapp information updated in {WEBAPPS_INFO}")
    except Exception as e:
        logging.error(f"Failed to update {WEBAPPS_INFO}: {e}")


def get_user_input():
    webapp_id = input("Enter webapp id (e.g 845135145): ")
    while not webapp_id.isdigit():
        print("Invalid input. Please enter a valid integer.")
        webapp_id = input("Enter webapp id (e.g 845135145): ")

    webapp_name = input("Enter webapp name as in Qualys (e.g PPROD_APP_INTRAXA): ")

    webapp_title = input("Enter webapp title: ")
    while not re.match(r'^[a-zA-Z0-9_-]+$', webapp_title):
        print("Invalid input. Please enter a title without special characters.")
        webapp_title = input("Enter webapp title: ")

    scope = input("Enter the scope of the web application ( Domain/Entity):  ").replace("\\", "/")
    webapp_url = input("Enter the webapp URL: ")
    webapp_env = input("Enter the webapp environment (e.g. PROD/PREPROD/UAT..): ")
    webapp_int = input("Enter the webapp internet posture (EXTERNAL/INTERNAL): ")
    while webapp_int not in ["EXTERNAL", "INTERNAL"]:
        webapp_int = input("Enter the webapp internet posture (EXTERNAL/INTERNAL): ")

    return int(webapp_id), webapp_name, webapp_title, scope, webapp_url, webapp_int, webapp_env


