    main()


def QualysWAS_url_to_webapp_name(was_url, default_scope="GO"):
    if not was_url:
        return None
    env = "PROD"  # default
    if "uat" in was_url:
        env = "UAT"
    if "stg" in was_url or "pp" in was_url:
        env = "PREPROD"

    try:
        res = get_tld(was_url, as_object=True)
        if res.tld == "axa" or res.tld == "com":
            scope = default_scope
        else:
            scope = res.tld.upper().replace('.', '')
        app = res.domain
        if res.subdomain:
            app = "%s-%s" % (res.domain, res.subdomain)
        webapp_name = "%s-%s-%s" % (env, app, scope)
        logging.info(f"Generated webapp name {webapp_name} from URL {was_url}")
        return webapp_name
    except Exception as e:
        logging.error(f"Failed to generate webapp name from URL {was_url}: {e}")
        scope = "GO"
        app = urlparse(was_url).netloc.upper().replace(".", "-")
        webapp_name = "%s-%s-%s" % (env, app, scope)
        logging.info(f"Generated webapp name {webapp_name} from URL {was_url} using fallback")
        return webapp_name


def write_to_csv(data, filename):
    headers = ["Id", "Name", "# Pages", "# Vulns", "Severity", "MDS Severity", "URL", "Last Scan Date", "Last Update Date", "Tags", "Domain", "Entity", "RiskScore"]

    with open(filename, mode='w', newline='', encoding='utf-8') as file:
        writer = csv.writer(file)
        writer.writerow(headers)
        writer.writerows(data)


def saveReportInfo(reportname, password, webappID, keepass_manager):
    line = ("%s,%s,%s\n") % (reportname, password, webappID)
    try:
        with open("GeneratedReport.txt", 'a+') as fh:
            fh.write(line)
        db = pykeepass.PyKeePass(BACKUP_PATH, password=vault_secrets['backup_password'])
        keepass_manager.add_entry_to_database(db, reportname, password, BACKUP_PATH)
        logging.info(f"Report info saved: {line}")
    except Exception as e:
        logging.error(f"Failed to save report info: {e}")


def generate_reports(config, webapps_info, applist, keepass_manager, sharepoint_sync):
    logging.info(f"Starting report generation for {applist}.")
    #sharepoint_url = config["sharepoint_url"]
    #site_name = config["sharepoint_site"]

    reportdir = "./reports/"
    if not os.path.exists(reportdir):
        try:
            os.mkdir(reportdir)
        except OSError as e:
            logging.error(f"Problem creating report directory: {e}")

    with open(applist, newline='') as csvfile:
        spamreader = csv.reader(csvfile, delimiter=',', quotechar='|')
        for row in spamreader:
            if not row[0]:
                continue
            appID = row[0]
            password = row[1] if row[1] else generate_password()
            try:
                reportName = qualys_api.create_report_name(appID)
                logging.info(f"Generating encrypted report: {reportName}")
                reportID = qualys_api.create_encrypted_report(appID, reportName, password)
                if reportID:
                    logging.info(f"Downloading {reportName}.")
                    qualys_api.download_report(reportID, reportName, reportdir)
                    qualys_api.delete_report(reportID)
                    saveReportInfo(reportName, password, appID, keepass_manager)
                    sharepoint_sync.deliver_report("%s.pdf" % reportName, appID)
            except Exception as e:
                logging.error(f"Failed to process report for webapp ID {appID}: {e}")
                continue


    try:
        if not os.path.exists('GeneratedReport.txt'):
            logging.error("GeneratedReport.txt file not found. Exiting report generation.")
            return

        mdb = pykeepass.PyKeePass(MASTER_KDBX, password=vault_secrets['master_password'])

        with open('GeneratedReport.txt', 'r') as f:
            entries = f.readlines()
        entries_dict = {title: (password, webapp_id) for title, password, webapp_id in
                        (entry.strip().split(',') for entry in entries)}

        for title, (password, webapp_id) in entries_dict.items():
            try:
                database_password_entry = mdb.find_entries(title=webapp_id, first=True)
                if not database_password_entry:
                    kdbx_path_to_find = webapps_info[webapp_id]["kdbx_path"]
                    matching_webapp_ids = [i for i, info in webapps_info.items() if
                                           info["kdbx_path"] == kdbx_path_to_find]
                    found_entry = False
                    for matching_id in matching_webapp_ids:
                        database_password_entry = mdb.find_entries(title=matching_id, first=True)
                        if database_password_entry:
                            logging.info(f"Found entry for webapp ID {matching_id}.")
                            found_entry = True
                            break
                if not database_password_entry:
                    logging.error(
                        f"Error, couldn't find the kdbx password in Apps.kdbx for {title}. Add {webapp_id} to Apps.kdbx")
                    continue

                database_password = database_password_entry.password
                webapp_info = webapps_info[webapp_id]
                path = os.path.join(WAS_REPORTS_PATH, webapp_info["kdbx_path"])
                shutil.copy(str(path), str(path) + '.bak')
                db = pykeepass.PyKeePass(path, password=database_password)
                keepass_manager.add_entry_to_database(db, title, password, path)
                logging.info(f"Password saved in KeePass for webapp {title}.")
            except Exception as e:
                logging.error(f"Error saving password for webapp {title}. Error: {e}")

        main()
    except Exception as e:
        logging.error(f"Error opening KeePass database: {e}")


def main():
    global vault_secrets
    global qualys_api
    global sharepoint_api


    keepass_manager = KeePassManager(MASTER_KDBX, ROOT_KDBX)
    logging.info("Initialized KeePass Manager.")
    vault_secrets = initialize_vault(keepass_manager)
    logging.info("Initialized Vault.")
    webapps_info = load_webapps_info()
    logging.info("Configuration loaded.")
    qualys_api = QualysAPI(config, vault_secrets['qualys_user'], vault_secrets['qualys_pwd'],
                           vault_secrets['proxy_user'], vault_secrets['proxy_password'])
    logging.info("Initialized Qualys API.")
    sharepoint_sync = SharepointSync(WAS_REPORTS_PATH, webapps_info)
    logging.info("Initialized Sharepoint API.")

    while True:
        print("Choose an option:")
        logging.info("Displaying main menu options.")
        print("1. Generate reports")
        print("2. Onboard")
        print("3. Generate Webapp name from URL")
        choice = input("Enter your choice: ")
        logging.info(f"User selected option {choice} from main menu.")

        if choice == "1":
            print("-------------------------")
            print("1. Applist")
            print("2. Tag")
            choice = input("Enter your choice: ")
            logging.info(f"User selected option {choice} from report generation menu.")
            if choice == "1":
                applist = "applist.csv"
            elif choice == "2":
                tag_name = input("Enter Tag: ")
                qualys_api.get_list_by_tag(tag_name)
                applist = "tag.csv"
            generate_reports(config, webapps_info, applist, keepass_manager, sharepoint_sync)

        elif choice == "2":
            onboard(keepass_manager)

        elif choice == "3":
            url = input("Enter a URL: ")
            webapp_name = QualysWAS_url_to_webapp_name(url)
            if webapp_name:
                print("Webapp name:", webapp_name)
        else:
            print("Invalid choice. Please try again.")
            logging.warning("User entered an invalid option in the main menu.")


if __name__ == "__main__":
    main()
