# =========================
# MAIN MENU
# =========================
def main():
    config = load_config()

    while True:
        print("\nChoose an option:")
        print("1. Generate reports")
        print("2. Onboard")
        print("3. Generate Webapp name from URL")
        print("4. Exit")

        choice = input("Enter your choice: ")

        if choice == "1":
            generate_reports(config)

        elif choice == "2":
            onboard()

        elif choice == "3":
            generate_webapp_name()

        elif choice == "4":
            print("Exiting...")
            break

        else:
            print("Invalid choice")


