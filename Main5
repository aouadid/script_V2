# =========================
# VAULT
# =========================
def initialize_vault(keepass_manager):
    logging.info("Initializing vault...")

    if not os.path.exists(VAULT_KDBX):
        vault_password = generate_password()
        keepass_manager.create_keepass_db(kdbx_path=VAULT_KDBX, password=vault_password)
        print(f"Vault password: {vault_password}")
        input("Save it and press enter...")

    try:
        vault_password = "e2fr1Ey!TWb9LPOFwC#e$Hx4"  # ⚠️ replace later
        kp = pykeepass.PyKeePass(VAULT_KDBX, password=vault_password)

        for secret in VAULT_SECRETS:
            entry = kp.find_entries(title=secret, first=True)
            if not entry or not entry.password:
                value = getpass(f"Enter value for {secret}: ")
                if entry:
                    entry.password = value
                else:
                    kp.add_entry(kp.root_group, title=secret, username="user", password=value)
                kp.save()

        secrets = {s: kp.find_entries(title=s, first=True).password for s in VAULT_SECRETS}
        logging.info("Vault loaded successfully.")
        return secrets

    except Exception as e:
        logging.error(f"Vault error: {e}")
        raise


# =========================
# HELPERS
# =========================
def generate_password():
    pwo = PasswordGenerator()
    pwo.minlen = 20
    pwo.maxlen = 25
    pwo.excludeschars = "^.*`'~,&"
    return pwo.generate()


def load_webapps_info():
    try:
        with open(WEBAPPS_INFO, 'r') as f:
            return json.load(f)
    except Exception as e:
        logging.error(f"Failed loading webapps_info: {e}")
        return {}


# =========================
# REPORT GENERATION
# =========================
def generate_reports(config, webapps_info, applist, keepass_manager, sharepoint_api):

    logging.info(f"Starting report generation for {applist}")

    reportdir = "./reports/"
    os.makedirs(reportdir, exist_ok=True)

    with open(applist, newline='') as csvfile:
        reader = csv.reader(csvfile)

        for row in reader:
            if not row or not row[0]:
                continue

            appID = row[0]
            password = row[1] if len(row) > 1 and row[1] else generate_password()

            try:
                if appID not in webapps_info:
                    logging.error(f"[SharePoint] {appID} missing in webapps_info")
                    continue

                reportName = qualys_api.create_report_name(appID)
                reportID = qualys_api.create_encrypted_report(appID, reportName, password)

                if not reportID:
                    logging.error(f"Failed to create report for {appID}")
                    continue

                qualys_api.download_report(reportID, reportName, reportdir)
                qualys_api.delete_report(reportID)

                saveReportInfo(reportName, password, appID, keepass_manager)

                local_file = os.path.join(reportdir, f"{reportName}.pdf")

                logging.info(f"[SharePoint] Uploading {local_file}")
                logging.info(f"[SharePoint] Target folder: {webapps_info[appID]['paths_path']}")

                print(f"Uploading {reportName}.pdf → {webapps_info[appID]['paths_path']}")

                # 🔥 NEW UPLOAD
                sharepoint_api.upload_file(local_file, appID)

                logging.info(f"[SharePoint] Upload SUCCESS for {appID}")

            except Exception as e:
                logging.error(f"Error for {appID}: {e}")
                logging.error(traceback.format_exc())


