# 🔐 VAULT
def initialize_vault(keepass_manager):
    logging.info("Initializing vault...")

    vault_password = "e2fr1Ey!TWb9LPOFwC#e$Hx4"  # ⚠️ TEMP (keep as you had)

    kp = pykeepass.PyKeePass(VAULT_KDBX, password=vault_password)

    for secret in VAULT_SECRETS:
        entry = kp.find_entries(title=secret, first=True)
        if not entry or not entry.password:
            secret_value = getpass(f"Enter value for {secret}: ")
            if entry:
                entry.password = secret_value
            else:
                kp.add_entry(kp.root_group, title=secret, username="user", password=secret_value)
            kp.save()

    secrets = {secret: kp.find_entries(title=secret, first=True).password for secret in VAULT_SECRETS}

    logging.info("Vault loaded successfully")
    logging.debug(f"Vault keys: {list(secrets.keys())}")  # ✅ DEBUG

    return secrets


# 🔐 PASSWORD
def generate_password():
    pwo = PasswordGenerator()
    pwo.minlen = 20
    pwo.maxlen = 25
    pwo.excludeschars = "^.*`'~,&"
    return pwo.generate()


# 📂 LOAD WEBAPPS
def load_webapps_info():
    try:
        with open(WEBAPPS_INFO, 'r') as jsonfile:
            return json.load(jsonfile)
    except Exception as e:
        logging.error(f"Failed to load webapps info: {e}")
        return {}


# 📊 REPORT GENERATION
def generate_reports(config, webapps_info, applist, keepass_manager, sharepoint_api):
    logging.info(f"Starting report generation for {applist}")

    reportdir = "./reports/"
    os.makedirs(reportdir, exist_ok=True)

    with open(applist, newline='') as csvfile:
        reader = csv.reader(csvfile)

        for row in reader:
            if not row[0]:
                continue

            appID = row[0]
            password = row[1] if row[1] else generate_password()

            try:
                reportName = qualys_api.create_report_name(appID)

                logging.info(f"Generating report {reportName}")

                reportID = qualys_api.create_encrypted_report(appID, reportName, password)

                if reportID:
                    qualys_api.download_report(reportID, reportName, reportdir)
                    qualys_api.delete_report(reportID)

                    file_path = f"{reportdir}/{reportName}.pdf"

                    # ✅ UPLOAD TO SHAREPOINT
                    try:
                        folder_path = f"Reports/{appID}"
                        sharepoint_api.upload_file(file_path, folder_path)

                        logging.info(f"Uploaded {reportName} to SharePoint")

                    except Exception as e:
                        logging.error(f"SharePoint upload failed: {e}")

            except Exception as e:
                logging.error(f"Error processing {appID}: {e}")
                continue


