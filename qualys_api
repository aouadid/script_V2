import logging
import os
import traceback
import requests
from requests.adapters import HTTPAdapter
from urllib3.util.retry import Retry
import urllib3

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)


class SharePointAPI:
    def __init__(self, config, client_id, client_secret, tenant_id):
        logging.debug("🔧 Initializing SharePointAPI...")

        self.session = requests.Session()
        self.client_id = client_id
        self.client_secret = client_secret
        self.tenant_id = tenant_id

        self.sharepoint_site = config["sharepoint_site"]
        self.site_name = config["sharepoint_site_name"]

        self.https_verify = False

        # Retry strategy
        retries = Retry(total=5, backoff_factor=0.3,
                        status_forcelist=[500, 502, 503, 504])
        self.session.mount('https://', HTTPAdapter(max_retries=retries))

        # 🔐 Authenticate
        self.token = self._authenticate()

        # Add token to session headers
        self.session.headers.update({
            "Authorization": f"Bearer {self.token}",
            "Content-Type": "application/octet-stream"
        })

        logging.debug("🔑 Token added to session headers")

        # 🔎 Resolve IDs
        self.site_id = self._get_site_id()
        self.drive_id = self._get_drive_id()

        logging.info(f"✅ SharePoint initialized | site_id={self.site_id} | drive_id={self.drive_id}")

    # =========================
    # 🔐 AUTHENTICATION
    # =========================
    def _authenticate(self):
        logging.debug("🔐 Starting SharePoint authentication...")

        url = f"https://login.microsoftonline.com/{self.tenant_id}/oauth2/v2.0/token"

        data = {
            'grant_type': 'client_credentials',
            'client_id': self.client_id,
            'client_secret': self.client_secret,
            'scope': 'https://graph.microsoft.com/.default'
        }

        try:
            response = self.session.post(url, data=data, verify=False)

            logging.debug(f"Auth response status: {response.status_code}")

            if response.status_code == 200:
                token = response.json()['access_token']
                logging.info("✅ SharePoint authentication SUCCESS")
                return token
            else:
                logging.error(f"❌ Auth failed: {response.text}")
                raise Exception("Authentication failed")

        except Exception as e:
            logging.error(f"❌ Exception during authentication: {e}")
            logging.error(traceback.format_exc())
            raise

    # =========================
    # 🔎 GET SITE ID
    # =========================
    def _get_site_id(self):
        logging.debug("🔎 Resolving site_id...")

        url = f"https://graph.microsoft.com/v1.0/sites/{self.sharepoint_site}:/sites/{self.site_name}"

        logging.debug(f"Site lookup URL: {url}")

        try:
            response = self.session.get(url, verify=False)

            logging.debug(f"Site response status: {response.status_code}")
            logging.debug(f"Site response text: {response.text}")

            if response.status_code == 200:
                site_id = response.json()["id"]
                logging.info(f"✅ site_id resolved: {site_id}")
                return site_id
            else:
                raise Exception("Failed to resolve site_id")

        except Exception as e:
            logging.error(f"❌ Error getting site_id: {e}")
            logging.error(traceback.format_exc())
            raise

    # =========================
    # 🔎 GET DRIVE ID
    # =========================
    def _get_drive_id(self):
        logging.debug("🔎 Resolving drive_id...")

        url = f"https://graph.microsoft.com/v1.0/sites/{self.site_id}/drives"

        logging.debug(f"Drive lookup URL: {url}")

        try:
            response = self.session.get(url, verify=False)

            logging.debug(f"Drive response status: {response.status_code}")
            logging.debug(f"Drive response text: {response.text}")

            if response.status_code == 200:
                drive_id = response.json()["value"][0]["id"]
                logging.info(f"✅ drive_id resolved: {drive_id}")
                return drive_id
            else:
                raise Exception("Failed to resolve drive_id")

        except Exception as e:
            logging.error(f"❌ Error getting drive_id: {e}")
            logging.error(traceback.format_exc())
            raise

    # =========================
    # 📤 UPLOAD FILE
    # =========================
    def upload_file(self, file_path, folder_path):
        file_name = os.path.basename(file_path)

        logging.info(f"📤 Starting upload: {file_name}")
        logging.debug(f"📁 Local file path: {file_path}")
        logging.debug(f"📂 Target SharePoint folder: {folder_path}")

        try:
            url = f"https://graph.microsoft.com/v1.0/sites/{self.site_id}/drives/{self.drive_id}/root:/{folder_path}/{file_name}:/content"

            logging.debug(f"Upload URL: {url}")

            if not os.path.exists(file_path):
                logging.error(f"❌ File does not exist: {file_path}")
                return

            file_size = os.path.getsize(file_path)
            logging.debug(f"📦 File size: {file_size} bytes")

            with open(file_path, "rb") as f:
                response = self.session.put(url, data=f, verify=False)

            logging.debug(f"Upload response status: {response.status_code}")
            logging.debug(f"Upload response text: {response.text}")

            if response.status_code in [200, 201]:
                logging.info(f"✅ Upload SUCCESS: {file_name} → {folder_path}")
            else:
                logging.error(f"❌ Upload FAILED: {response.text}")

        except Exception as e:
            logging.error(f"❌ Exception during upload: {e}")
            logging.error(traceback.format_exc())
